{
  "name": "@inova.dev/jelly-ui",
  "version": "0.1.0",
  "description": "A glowing 3D-jelly + liquid-glass icon-button material for React. One accent colour drives an emissive core, subsurface shade, bloom, gloss and rim light — with frosted-glass and colourless variants.",
  "type": "module",
  "license": "MIT",
  "author": "inova.dev",
  "sideEffects": false,
  "keywords": [
    "react",
    "ui",
    "button",
    "icon-button",
    "jelly",
    "glass",
    "liquid-glass",
    "design-system",
    "css",
    "component"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./icons": {
      "import": {
        "types": "./dist/icons.d.ts",
        "default": "./dist/icons.js"
      },
      "require": {
        "types": "./dist/icons.d.cts",
        "default": "./dist/icons.cjs"
      }
    },
    "./styles.css": "./dist/jelly.css",
    "./styles.min.css": "./dist/jelly.min.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
